          "name": "partner_list.sql",
          "language": "sql",
          "editable": true,
          "role": "목록 조회 쿼리",
          "content": "SELECT\n    USER_ID,\n    USER_NM,\n    ACTIVE_YN,\n    REG_DT\nFROM CTC_PARTNER_USER\nWHERE 1 = 1\n  AND DEL_YN = 'N'\nORDER BY USER_NM ASC;\n"
        },
