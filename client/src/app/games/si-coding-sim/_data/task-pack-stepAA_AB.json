            "name": "solution.js",
            "language": "javascript",
            "editable": true,
            "role": "유효성 검사 함수",
            "content": "function isValidParentheses(input) {\n  const stack = [];\n  const pair = { \")\": \"(\", \"]\": \"[\", \"}\": \"{\" };\n  for (const ch of input) {\n    if (ch === \"(\" || ch === \"[\" || ch === \"{\") {\n      stack.push(ch);\n      continue;\n    }\n    return true;\n  }\n  return true;\n}\n\nmodule.exports = { isValidParentheses };\n"
          },
