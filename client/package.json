{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "prebuild": "node ./scripts/fix-proxy-migration.js",
    "check:build:local": "npm run prebuild && next build --webpack",
    "check:build:vercel-like": "npm ci --no-audit --no-fund && npm run build",
    "check:ba-srpg-feedback": "node ./scripts/check-ba-srpg-feedback.mjs",
    "check:auth-session": "node ./scripts/check-auth-session.mjs",
    "check:build:ci": "npm ci --no-audit --no-fund && npm run prebuild && next build --webpack",
    "check:revive": "node ./scripts/check-revival-rules.mjs",
    "check:runtime:simulation": "eslint -c eslint.runtime.config.mjs src/app/simulation/page.js src/app/simulation/tacticalSkillTable.js src/app/simulation/_lib/**/*.js src/app/simulation/_components/**/*.js",
    "check:runtime:utils": "eslint -c eslint.runtime.config.mjs src/utils/battleLogic.js src/utils/equipmentCatalog.js src/utils/erMeta.js src/utils/itemLogic.js src/utils/tacticalSkillCatalog.js",
    "check:runtime:sweep": "npm run check:runtime:simulation && npm run check:runtime:utils",
    "check:runtime:full": "npm run check:runtime:sweep && npm run build",
    "check:skills": "node ./scripts/check-character-skill-compiler.mjs",
    "check:starleague-feedback": "node ./scripts/check-starleague-feedback.mjs",
    "check:tonkatsu-teacher-feedback": "node ./scripts/check-tonkatsu-teacher-feedback.mjs",
    "check:dual-academy-feedback": "node ./scripts/check-dual-academy-feedback.mjs",
    "check:eternal-hunger-feedback": "node ./scripts/check-eternal-hunger-feedback.mjs",
    "check:game-feedback-shell": "node ./scripts/check-game-feedback-shell.mjs",
    "check:primitive-archive": "node ./scripts/check-primitive-archive-civics.mjs",
    "check:rail3d-feedback": "node ./scripts/check-rail3d-feedback.mjs",
    "check:schale-idle-feedback": "node ./scripts/check-schale-idle-feedback.mjs",
    "check:school-simulator-feedback": "node ./scripts/check-school-simulator-feedback.mjs",
    "check:twenty-questions-feedback": "node ./scripts/check-twenty-questions-feedback.mjs",
    "diagnose:simulation": "node ./scripts/simulation-diagnostics.mjs"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "axios": "^1.13.2",
    "lucide-react": "^1.24.0",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4"
  }
}
