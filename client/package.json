{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prebuild": "node ./scripts/fix-proxy-migration.js",
    "check:build:local": "npm run prebuild && npx next build",
    "check:build:vercel-like": "npm ci --no-audit --no-fund && npm run build",
    "check:build:ci": "npm ci --no-audit --no-fund && npm run prebuild && npx next build",
    "check:runtime:sweep": "eslint -c eslint.runtime.config.mjs src/app/simulation/page.js",
    "check:runtime:full": "npm run check:runtime:sweep && npm run build"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "axios": "^1.13.2",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4"
  }
}
